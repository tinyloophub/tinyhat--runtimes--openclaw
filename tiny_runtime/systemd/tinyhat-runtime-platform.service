[Unit]
Description=Tinyhat tiny_runtime platform loop
Wants=network-online.target tinyhat-runtime-gateway.service tinyhat-runtime-attestation.service
After=network-online.target tinyhat-runtime-gateway.service tinyhat-runtime-attestation.service

[Service]
Type=simple
EnvironmentFile=-/etc/tinyhat/runtime.env
WorkingDirectory=/opt/tinyhat/current
ExecStart=/opt/tinyhat/current/bin/tinyhat-runtime platform loop
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
